DATABASE_URL=postgresql://postgres:postgres@postgres:5432/new_release_tracker?schema=public
REDIS_URL=redis://redis:6379
APP_URL=http://localhost:3000

# Optional provider auth and account-link credentials
# Leave these empty unless you want to enable the matching provider flows.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
TIDAL_CLIENT_ID=
TIDAL_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_MUSIC_DEVELOPER_TOKEN=
DEEZER_APP_ID=
DEEZER_APP_SECRET=

# Optional import and provider behavior
LASTFM_API_KEY=
DEEZER_RATE_LIMIT_RETRIES=6
DEEZER_RATE_LIMIT_BASE_DELAY_MS=15000

# Freshwax session and sync settings
SESSION_COOKIE_NAME=nrt_session
SESSION_TTL_DAYS=30
SYNC_INTERVAL_MINUTES=360
ARTIST_SYNC_CONCURRENCY=1
DEFAULT_TIMEZONE=Europe/Amsterdam
