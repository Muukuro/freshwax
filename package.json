{
  "name": "new-release-tracker",
  "version": "0.0.2",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "dev:worker": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs watch src/worker.ts",
    "dev:all": "concurrently -k -n app,worker -c blue,yellow \"npm:dev\" \"npm:dev:worker\"",
    "build": "next build",
    "start": "next start",
    "start:worker": "tsx src/worker.ts",
    "lint": "eslint --max-warnings=0",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.79.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "ioredis": "^5.6.1",
    "lucide-react": "^0.511.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "prisma": "^6.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsx": "^4.22.4",
    "web-push": "^3.6.7",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4.3.1",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
